<!DOCTYPE html>
<% import software.altitude.core.Api %>
<% import software.altitude.core.AltitudeServletContext %>
<% import software.altitude.core.RequestContext %>

<html lang="en">
<head>
    <title>ALTITUDE</title>

    <% include("includes/header_common.ssp") %>

    <style>
        html, body {
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body {
            flex: 1;
        }

        #explorer {
            border-right: 1px solid var(--panel-border-color);
            box-shadow: var(--box-shadow);
            text-shadow: rgba(0,0,0,0.75) 0 1px;
            padding-top: var(--panel-padding);
        }

        #explorerPanels {
            box-shadow: var(--box-shadow);
            text-shadow: rgba(0,0,0,0.75) 0 1px;
        }

        #infoPanel {
            border-top: 1px solid var(--panel-border-color);
            box-shadow: var(--box-shadow);
            text-shadow: rgba(0,0,0,0.75) 0 1px;
        }

        #content {
            border-left: 1px solid var(--panel-border-color);
            box-shadow: var(--box-shadow);
            text-shadow: rgba(0,0,0,0.75) 0 1px;
            overflow-y: scroll;
            max-width: 100%;
        }

        #explorerPanelContent {
            overflow-y: auto;
            max-height: 100%;
        }

        /* Resizable grid */
        .panes {
            touch-action: none;
            display: grid;
        }

        .panes-v {
            height: 100%;
        }

        .pane {
            position: relative;
            overflow-y: hidden;
        }
        .gutter {
            position: absolute;
            bottom: 0;
            right: 0;
            z-index: 3;
            background: transparent;
        }

        .panes-h > .pane > .gutter {
            cursor: col-resize;
            top: 0;
            bottom: 0;
            width: 8px;
        }

        .panes-v > .pane > .gutter {
            cursor: row-resize;
            left: 0;
            height: 8px;
        }
    </style>
</head>

<body>

<script type="module">
    const els = (sel, par = document) => document.querySelectorAll(sel);
    const elNew = (tag, prop = {}) => Object.assign(document.createElement(tag), prop);

    let isResizing = false;
    let frNext = 0;

    const resizableGrid = (elParent, idx) => {
        const isVert = elParent.classList.contains("panes-v");
        const elsPanes = elParent.querySelectorAll(":scope > .pane");

        let fr = [...elsPanes].map(() => 1 / elsPanes.length);
        let elPaneCurr = null;
        let paneIndex = -1;
        let frStart = 0;
        const frToCSS = () => {
            elParent.style[isVert ? "grid-template-rows" : "grid-template-columns"] = fr.join("fr ") + "fr";
        };

        const pointerDown = (evt) => {
            if (isResizing || !evt.target.closest(".gutter")) return;
            isResizing = true;
            elPaneCurr = evt.currentTarget;
            fr = [...elsPanes].map((elPane) => isVert ? elPane.clientHeight / elParent.clientHeight : elPane.clientWidth / elParent.clientWidth);
            paneIndex = [...elsPanes].indexOf(elPaneCurr);
            frStart = fr[paneIndex];
            frNext = fr[paneIndex + 1];
            addEventListener("pointermove", pointerMove);
            addEventListener("pointerup", pointerUp);
        };

        const pointerMove = (evt) => {
            evt.preventDefault();
            const paneBCR = elPaneCurr.getBoundingClientRect();
            const parentSize = isVert ? elParent.clientHeight : elParent.clientWidth;
            const pointer = {
                x: Math.max(0, Math.min(evt.clientX - paneBCR.left, elParent.clientWidth)),
                y: Math.max(0, Math.min(evt.clientY - paneBCR.top, elParent.clientHeight))
            };
            const frRel = pointer[isVert ? "y" : "x"] / parentSize;
            const frDiff = frStart - frRel;
            fr[paneIndex] = Math.max(0.05, frRel);
            fr[paneIndex + 1] = Math.max(0.05, frNext + frDiff);
            frToCSS();
        };

        const pointerUp = (evt) => {
            removeEventListener("pointermove", pointerMove);
            removeEventListener("pointerup", pointerUp);
            isResizing = false;
        };

        [...elsPanes].slice(0, -1).forEach((elPane, i) => {
            elPane.append(elNew("div", {
                className: "gutter"
            }));
            elPane.addEventListener("pointerdown", pointerDown);
        });
        frToCSS();
    };

    els(".panes").forEach(resizableGrid);
</script>

<main class="panes panes-v">
    <!-- Modals, snackbars, etc-->
    <% include("includes/html_common.ssp") %>

    <% include("includes/nav.ssp") %>

    <div id="explorer" class="pane panes panes-h">
        <div id="explorerPanels" class="pane panes panes-v">
            <div class="pane">
                <tab-container>
                    <div role="tablist">
                        <button type="button" id="foldersTab" role="tab"
                                data-tab-container-no-tabstop>
                            <a href="#"
                               hx-target="#explorerPanelContent"
                               hx-swap="innerHTML"
                               hx-trigger="load, click"
                               hx-get='${ url(showFoldersTab, Api.Field.REPO_ID -> RequestContext.getRepository.persistedId) }'>Folders</a>
                        </button>

                        <button type="button" id="albumsTab" role="tab"
                                data-tab-container-no-tabstop>
                            <a href="#"
                               hx-target="#explorerPanelContent"
                               hx-trigger="click"
                               hx-swap="innerHTML"
                               hx-get='${ url(showAlbumsTab, Api.Field.REPO_ID -> RequestContext.getRepository.persistedId) }'>Albums</a>
                        </button>

                        <button type="button" id="peopleTab" role="tab"
                                data-tab-container-no-tabstop>
                            <a href="#"
                               hx-target="#explorerPanelContent"
                               hx-trigger="click"
                               hx-swap="innerHTML"
                               hx-get='${ url(showPeopleTab, Api.Field.REPO_ID -> RequestContext.getRepository.persistedId) }'>People</a>
                        </button>
                    </div>

                    <div id="explorerPanelContent" role="tabpanel" class="tab-content">
                    </div>

                </tab-container>
            </div>
            <div id="infoPanel" class="pane"></div>
        </div>
        <div id="content" class="pane">
            <% include("includes/search_results.ssp") %>
        </div>
    </div>

    <footer>
        <%= RequestContext.account.value.getOrElse("None") %>
    </footer>

</main>


</body>
</html>
